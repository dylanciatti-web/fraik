<!-- ── Bundle Solo / Duo / Trio ── -->
<div class="fraik-wrap fraik-bundle-wrap">
  <section class="fraik-bundle">
    <div class="fraik-section-head">
      <div class="fraik-eyebrow">Économise plus</div>
      <h2>Choisis ton offre</h2>
    </div>
    <div class="bundle-grid">
      <div class="bundle-card">
        <div class="bundle-qty">× 1 unité</div>
        <div class="bundle-name">Solo</div>
        <div class="bundle-desc">Pour ta chambre ou ton bureau</div>
        <div class="bundle-price">{{ product.price | money_without_currency | append: ' €' }}</div>
        {% form 'product', product, id: 'fraik-bundle-solo', novalidate: 'novalidate' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <input type="hidden" name="return_to" value="/checkout">
          <button type="submit" name="add" class="fraik-btn" {%- unless product.available %} disabled aria-disabled="true"{%- endunless -%}>{%- if product.available -%}Commander →{%- else -%}Rupture de stock{%- endif -%}</button>
        {% endform %}
      </div>
      <div class="bundle-card best">
        <div class="bundle-popular">⭐ LE PLUS POPULAIRE</div>
        <div class="bundle-qty">× 2 unités</div>
        <div class="bundle-name">Duo</div>
        <div class="bundle-desc">Chambre + bureau, ou en offrir un</div>
        <div class="bundle-price-block">
          <span class="price-then">{{ product.price | times: 2 | money_without_currency | append: ' €' }}</span>
          <div class="bundle-price-row">
            <div class="bundle-price">69,99 €</div><span class="price-save">−12%</span>
          </div>
        </div>
        {% form 'product', product, id: 'fraik-bundle-duo', novalidate: 'novalidate' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="2">
          <input type="hidden" name="return_to" value="/checkout">
          <button type="submit" name="add" class="fraik-btn" {%- unless product.available %} disabled aria-disabled="true"{%- endunless -%}>{%- if product.available -%}Commander →{%- else -%}Rupture de stock{%- endif -%}</button>
        {% endform %}
      </div>
      <div class="bundle-card">
        <div class="bundle-qty">× 3 unités</div>
        <div class="bundle-name">Trio</div>
        <div class="bundle-desc">Toute la maison au frais</div>
        <div class="bundle-price-block">
          <span class="price-then">{{ product.price | times: 3 | money_without_currency | append: ' €' }}</span>
          <div class="bundle-price-row">
            <div class="bundle-price">99,99 €</div><span class="price-save">−17%</span>
          </div>
        </div>
        {% form 'product', product, id: 'fraik-bundle-trio', novalidate: 'novalidate' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="3">
          <input type="hidden" name="return_to" value="/checkout">
          <button type="submit" name="add" class="fraik-btn" {%- unless product.available %} disabled aria-disabled="true"{%- endunless -%}>{%- if product.available -%}Commander →{%- else -%}Rupture de stock{%- endif -%}</button>
        {% endform %}
      </div>
    </div>
    <p class="fraik-stock-badge">🔴 Plus que quelques unités en stock suite à la vague de chaleur</p>
  </section>
