<div class="fraik-page-flow">

<div class="fraik-wrap fraik-hero-wrap">
  <section class="fraik-hero">

    <div class="gallery">
      <div class="gallery-tag">3 EN 1 · 🇫🇷 Entreprise française</div>
      <div class="gallery-main">
        {%- assign product_videos = product.media | where: 'media_type', 'video' -%}
        {%- assign product_video = product_videos.first -%}
        {%- if product.featured_image -%}
          <img id="fraik-main-img"
               src="{{ product.featured_image | image_url: width: 900 }}"
               alt="{{ product.featured_image.alt | default: product.title }}"
               style="width:100%;height:100%;object-fit:contain;border-radius:8px;cursor:pointer;{% if product_video %}display:none;{% endif %}">
        {%- else -%}
          <span style="font-size:48px;">❄</span>
        {%- endif -%}
        {%- if product_video -%}
          <video id="fraik-main-video"
                 autoplay loop muted playsinline preload="metadata"
                 poster="{{ product_video.preview_image | image_url: width: 900 }}"
                 style="width:100%;height:100%;object-fit:contain;border-radius:8px;background:#000;">
            {%- for source in product_video.sources -%}
              {%- if source.mime_type == 'video/mp4' -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endif -%}
            {%- endfor -%}
          </video>
        {%- endif -%}
      </div>
      <div class="gallery-thumbs">
        {%- comment -%} 1) Vidéo (upload Shopify natif) {%- endcomment -%}
        {%- if product_video -%}
          <div class="thumb thumb-video active" onclick="fraikShowVideo(this)">
            <img src="{{ product_video.preview_image | image_url: width: 160 }}" alt="Vidéo de démonstration {{ product.title | escape }}" loading="lazy">
            <span class="thumb-play" aria-hidden="true">▶</span>
          </div>
        {%- endif -%}
        {%- comment -%} 2) Image hero {%- endcomment -%}
        {%- if product.featured_image -%}
          <div class="thumb{% unless product_video %} active{% endunless %}"
               data-full="{{ product.featured_image | image_url: width: 900 }}"
               data-alt="{{ product.featured_image.alt | default: product.title | escape }}"
               onclick="fraikShowImage(this)">
            <img src="{{ product.featured_image | image_url: width: 160 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy">
          </div>
        {%- endif -%}
        {%- comment -%} 3) Autres images (on saute l'image hero déjà affichée) {%- endcomment -%}
        {%- for image in product.images limit: 8 -%}
          {%- unless image.id == product.featured_image.id -%}
            <div class="thumb"
                 data-full="{{ image | image_url: width: 900 }}"
                 data-alt="{{ image.alt | default: product.title | escape }}"
                 onclick="fraikShowImage(this)">
              <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | default: product.title | escape }}" loading="lazy">
            </div>
          {%- endunless -%}
        {%- endfor -%}
        {%- unless product.featured_image or product_video or product.images.size > 0 -%}
          <div class="thumb active">❄</div>
          <div class="thumb">≋</div>
          <div class="thumb">✦</div>
          <div class="thumb">⇄</div>
        {%- endunless -%}
      </div>
    </div>

    <div class="fraik-hero-copy">
      <div class="stars-line">
        <a href="#fraik-reviews"><span class="stars">★★★★★</span> 4,8/5 · 59 avis vérifiés</a>
      </div>
      <div class="fraik-eyebrow">{{ product.type | default: "Ventilateur Rafraîchisseur d'Air Portable" }}</div>
      <h1>15h, 34°C, pas de clim ? <span class="fraik-accent">Fraïk te rafraîchit en moins de 10 secondes</span>.</h1>
      <div class="hero-sub-args">Une brume fraîche et un flux d'air réglable, droit sur toi.</div>

      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- assign sell_price      = current_variant.price -%}
      {%- assign compare_price   = current_variant.compare_at_price -%}
      <div class="price-block">
        <span class="price-now">{{ sell_price | money_without_currency | append: ' €' }}</span>
        {%- if compare_price > sell_price -%}
          <span class="price-then">{{ compare_price | money_without_currency | append: ' €' }}</span>
          {%- assign savings_pct = compare_price | minus: sell_price | times: 100 | divided_by: compare_price -%}
          <span class="price-save">−{{ savings_pct }}%</span>
        {%- endif -%}
      </div>

      <div class="fraik-interest-counter" id="fraik-interest-counter-{{ section.id }}" data-interest-min="{{ section.settings.interest_min }}" data-interest-max="{{ section.settings.interest_max }}" data-interest-interval-min="{{ section.settings.interest_interval_min }}" data-interest-interval-max="{{ section.settings.interest_interval_max }}" role="status" aria-live="polite">
        <span class="fraik-interest-dot" aria-hidden="true"></span>
        <span class="fraik-interest-copy"><span>{{ section.settings.interest_label | escape }}</span><strong class="fraik-interest-number">{{ section.settings.interest_min }}</strong></span>
      </div>

      {%- if product.has_only_default_variant == false -%}
      <div class="fraik-variant-picker" id="fraik-variant-picker">
        {%- for option in product.options_with_values -%}
        <div class="fraik-option-group">
          <div class="fraik-option-label">{{ option.name }} : <span class="fraik-option-selected" id="fraik-opt-val-{{ option.position }}">{{ option.selected_value }}</span></div>
          <div class="fraik-option-values">
            {%- for value in option.values -%}
            <button type="button"
              class="fraik-opt-btn{% if option.selected_value == value %} active{% endif %}"
              data-option-pos="{{ option.position }}"
              data-option-val="{{ value | escape }}"
              aria-label="{{ option.name }}: {{ value }}">{{ value }}</button>
            {%- endfor -%}
          </div>
        </div>
        {%- endfor -%}
      </div>
      {%- endif -%}

      {% form 'product', product, id: 'fraik-product-form', novalidate: 'novalidate' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <input type="hidden" name="return_to" value="/checkout">
        <button type="submit" name="add" class="fraik-btn"
          {%- unless product.available %} disabled aria-disabled="true"{%- endunless -%}>
          {%- if product.available -%}Je veux sentir la fraîcheur → {{ product.price | money_without_currency | append: ' €' }}{%- else -%}Rupture de stock{%- endif -%}
        </button>
      {% endform %}
      <p class="fraik-stock-badge">🔴 Plus que quelques unités en stock suite à la vague de chaleur</p>

      <div class="hero-trust-line">Paiement sécurisé · Livraison suivie · Retour 15j</div>
      <div class="fraik-pay-badges">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'fraik-pay-icon' }}
        {%- endfor -%}
      </div>

      <div class="hero-guarantee">
        <strong>Décide sans pression</strong>
        <p>Tu disposes de 15 jours après réception pour demander un retour et ton remboursement.</p>
      </div>

    </div>

  </section>
</div>

