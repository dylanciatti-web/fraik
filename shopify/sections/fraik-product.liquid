      <span>Livraison offerte</span>
    </div>
    <div class="trust-item">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l7 3v5c0 5-3.2 8.4-7 10-3.8-1.6-7-5-7-10V6l7-3z" stroke="#0092A8" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 12l2 2 4-4.5" stroke="#0092A8" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
