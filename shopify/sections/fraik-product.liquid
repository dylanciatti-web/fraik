{% comment %}
  ┌─────────────────────────────────────────────────────────────────┐
  │  Section  : fraik-product                                       │
  │  Chemin   : sections/fraik-product.liquid                       │
  └─────────────────────────────────────────────────────────────────┘
{% endcomment %}

<style>
html{scroll-behavior:smooth;}
:root{
  --navy:#0A1628;
  --white:#FFFFFF;
  --ice:#F2F8FA;
  --ink:#0A1628;
  --steel:#4A6572;
  --cyan:#00C2D9;
  --cyan-deep:#0092A8;
  --line:#DCE9EC;
  --font-display:'Helvetica Neue',Arial,sans-serif;
  --font-body:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  --font-mono:'Courier New',monospace;
}
.fraik-wrap{max-width:1200px;margin:0 auto;padding:0 24px;}

/* ---- Bandeau défilant ---- */
.marquee-bar{background:var(--navy);overflow:hidden;white-space:nowrap;padding:10px 0;}
.marquee-track{display:inline-block;animation:fraik-scroll 22s linear infinite;font-family:var(--font-mono);font-size:12.5px;letter-spacing:0.06em;color:var(--white);}
.marquee-track span{margin-right:48px;color:var(--cyan);}
.mq-urgent{color:#D93025!important;}
@keyframes fraik-scroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ---- Hero ---- */
.fraik-hero{display:grid;grid-template-columns:1fr 1fr;gap:50px;padding:44px 0 30px;align-items:start;}
.gallery{position:relative;}
.gallery-main{aspect-ratio:1/1;background:linear-gradient(155deg,var(--ice),#E4F1F4);border:1px solid var(--line);border-radius:10px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.gallery-tag{display:inline-flex;align-items:center;font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:0.05em;color:var(--navy);background:var(--ice);border:1px solid var(--line);border-radius:4px;padding:5px 12px;margin-bottom:10px;}
.gallery-thumbs{display:flex;gap:10px;margin-top:12px;}
.thumb{flex:1;aspect-ratio:1/1;background:var(--ice);border:2px solid var(--line);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--cyan-deep);cursor:pointer;overflow:hidden;}
.thumb img{width:100%;height:100%;object-fit:contain;}
.thumb.active{border-color:var(--cyan-deep);}
.thumb-video{position:relative;}
.thumb-video img{object-fit:cover;}
.thumb-video .thumb-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:32px;height:32px;border-radius:50%;background:rgba(10,22,40,0.7);color:#fff;font-size:12px;display:flex;align-items:center;justify-content:center;padding-left:3px;pointer-events:none;}

/* ---- Infos produit ---- */
.fraik-eyebrow{font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.1em;color:var(--cyan-deep);text-transform:uppercase;font-weight:700;margin-bottom:10px;}
.fraik-hero h1{font-family:var(--font-display);font-size:26px;line-height:1.2;color:var(--navy);font-weight:800;letter-spacing:-0.01em;margin-bottom:0;}
.hero-sub-args{font-size:14px;line-height:1.55;color:var(--steel);margin-top:10px;max-width:440px;}
.stars-line{display:flex;align-items:center;gap:8px;margin-top:16px;font-size:13.5px;color:var(--steel);}
.stars-line .stars{color:#F5A623;letter-spacing:1px;}
.stars-line a{color:inherit;text-decoration:none;}
.stars-line a:hover{text-decoration:underline;}
.price-block{display:flex;align-items:baseline;gap:12px;margin-top:22px;}
.price-now{font-family:var(--font-display);font-size:32px;font-weight:800;color:var(--navy);}
.price-then{font-size:16px;color:var(--steel);text-decoration:line-through;opacity:0.7;}
.price-save{font-family:var(--font-mono);font-size:12px;font-weight:700;color:var(--cyan-deep);background:rgba(0,194,217,0.1);padding:4px 9px;border-radius:4px;}
.fraik-btn{width:100%;background:var(--cyan-deep);color:var(--white);border:none;padding:17px 30px;font-size:14.5px;font-weight:800;letter-spacing:0.03em;border-radius:6px;cursor:pointer;margin-top:20px;display:block;text-align:center;}
.fraik-btn:disabled{opacity:0.55;cursor:not-allowed;}
.hero-trust-line{font-family:var(--font-mono);font-size:11px;color:var(--steel);text-align:center;margin-top:10px;letter-spacing:0.04em;}
.fraik-pay-badges{display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;margin-top:8px;}
.fraik-pay-icon{height:24px;width:auto;display:inline-block;vertical-align:middle;}
.reassure-item .fraik-pay-badges{margin-top:8px;gap:6px;}
.reassure-item .fraik-pay-icon{height:20px;}

/* ---- Bénéfices hero ---- */
.fraik-benefits-list{list-style:none;margin:20px 0 0;padding:20px 0 0;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:14px;}
.fraik-benefits-list li{display:flex;gap:12px;align-items:flex-start;}
.fbl-icon{font-size:19px;flex-shrink:0;line-height:1.35;}
.fbl-text strong{display:block;font-size:13.5px;font-weight:700;color:var(--navy);margin-bottom:3px;line-height:1.3;}
.fbl-text p{font-size:12.5px;color:var(--steel);line-height:1.5;margin:0;}

/* ---- Sections générales ---- */
.fraik-section{padding:64px 0;}
.fraik-section-head{text-align:center;margin-bottom:40px;}
.fraik-section-head h2{font-family:var(--font-display);font-size:28px;color:var(--navy);font-weight:800;}
.reassure-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.reassure-item{background:var(--ice);border:1px solid var(--line);border-radius:10px;padding:26px 20px;text-align:center;}
.reassure-item .ic{font-size:22px;margin-bottom:12px;}
.reassure-item h4{font-size:13.5px;color:var(--navy);font-weight:700;margin-bottom:6px;}
.reassure-item p{font-size:12px;color:var(--steel);line-height:1.5;}

/* ---- Nettoyage ---- */
.clean-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
.clean-card{background:var(--ice);border:1px solid var(--line);border-radius:10px;overflow:hidden;}
.clean-card img{width:100%;display:block;aspect-ratio:4/3;object-fit:cover;}
.clean-caption{padding:16px 20px;font-family:var(--font-mono);font-size:11.5px;font-weight:700;color:var(--navy);letter-spacing:0.04em;line-height:1.45;}


/* ---- Fonds de section ---- */
.fraik-full-bg{width:100%;}
.fraik-bg-ice{background:var(--ice);}
.fraik-bg-mist{background:#EEF3F6;}

/* ---- CTA final ---- */
.fraik-final{background:var(--navy);padding:60px 0;text-align:center;}
.fraik-final h2{font-family:var(--font-display);font-size:30px;color:var(--white);font-weight:800;margin-bottom:12px;}
.fraik-final p{color:#B8CCD6;font-size:14.5px;margin-bottom:24px;}
.fraik-final .fraik-btn{width:auto;display:inline-block;padding:16px 36px;margin-top:0;}

/* ---- Bénéfices ---- */
.fraik-benefits{padding:48px 0;}
.benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.benefit-card{background:var(--ice);border:1px solid var(--line);border-radius:10px;padding:26px 20px;text-align:center;}
.benefit-card .ic{font-size:24px;margin-bottom:12px;}
.benefit-card h4{font-size:13.5px;color:var(--navy);font-weight:700;margin-bottom:8px;}
.benefit-card p{font-size:12.5px;color:var(--steel);line-height:1.5;}

/* ---- Bundle ---- */
.fraik-bundle{padding:48px 0;}
.bundle-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
.bundle-card{background:var(--ice);border:2px solid var(--line);border-radius:12px;padding:28px 22px 24px;text-align:center;position:relative;}
.bundle-card.best{border-color:var(--cyan-deep);background:var(--white);}
.bundle-popular{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--cyan-deep);color:var(--white);font-family:var(--font-mono);font-size:10px;font-weight:700;padding:4px 14px;border-radius:20px;letter-spacing:0.05em;white-space:nowrap;}
.bundle-qty{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--cyan-deep);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px;}
.bundle-name{font-family:var(--font-display);font-size:22px;font-weight:800;color:var(--navy);margin-bottom:6px;}
.bundle-desc{font-size:13px;color:var(--steel);margin-bottom:16px;}
.bundle-price{font-family:var(--font-display);font-size:28px;font-weight:800;color:var(--navy);margin-bottom:16px;}
.bundle-price-block{margin-bottom:16px;}
.bundle-price-block .bundle-price{margin-bottom:0;}
.bundle-price-block .price-then{display:block;font-size:14px;margin-bottom:4px;}
.bundle-price-row{display:flex;align-items:center;justify-content:center;gap:10px;}

/* ---- Avant/Après ---- */
.fraik-avap{padding:56px 0;}
.avap-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.avap-pair{display:flex;flex-direction:column;gap:8px;}
.avap-context{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--steel);text-transform:uppercase;letter-spacing:0.06em;margin:0 0 4px;}
.avap-item{position:relative;border-radius:10px;overflow:hidden;}
.avap-item img{width:100%;display:block;aspect-ratio:4/3;object-fit:cover;}
.avap-badge{position:absolute;top:10px;left:10px;font-family:var(--font-mono);font-size:10px;font-weight:700;padding:4px 10px;border-radius:3px;letter-spacing:0.06em;}
.avap-badge.avant{background:rgba(74,101,114,0.85);color:var(--white);}
.avap-badge.apres{background:var(--cyan-deep);color:var(--white);}

/* ---- Avis clients ---- */
.fraik-reviews{padding:56px 0 0;}
.reviews-header{text-align:center;margin-bottom:36px;}
.reviews-score-display{line-height:1;margin:10px 0 8px;}
.reviews-score-num{font-family:var(--font-display);font-size:48px;font-weight:800;color:var(--navy);}
.reviews-score-denom{font-family:var(--font-display);font-size:24px;font-weight:700;color:var(--steel);}
.reviews-stars-header{color:#00B67A;font-size:22px;letter-spacing:3px;margin-bottom:6px;}
.reviews-count-label{font-size:13.5px;color:var(--steel);}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.reviews-grid-more{margin-top:16px;}
.review-card{background:var(--white);border:1px solid var(--line);border-radius:12px;padding:20px;box-shadow:0 2px 8px rgba(10,22,40,0.06);min-width:0;overflow:hidden;}
.review-card-top{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
.review-avatar{width:40px;height:40px;border-radius:50%;background:var(--ice);border:1px solid var(--line);flex-shrink:0;overflow:hidden;}
.review-avatar svg{width:100%;height:100%;display:block;}
.review-avatar-photo{width:56px;height:56px;border-radius:8px;flex-shrink:0;overflow:hidden;border:1px solid var(--line);}
.review-avatar-photo img{width:100%;height:100%;object-fit:cover;display:block;}
@media(max-width:820px){.review-avatar-photo{width:64px;height:64px;}}
.review-meta{flex:1;min-width:0;}
.review-rating{color:#00B67A;font-size:13px;letter-spacing:1px;line-height:1;margin-bottom:3px;}
.review-author{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--navy);}
.review-text{font-size:13px;color:var(--steel);line-height:1.6;margin:0;overflow-wrap:break-word;word-break:break-word;}
.reviews-more-wrap{max-height:0;overflow:hidden;transition:max-height 0.55s ease;}
.reviews-toggle-wrap{text-align:center;margin-top:28px;}
.fraik-reviews-btn{background:transparent;border:2px solid var(--cyan-deep);color:var(--cyan-deep);padding:13px 28px;font-size:14px;font-weight:700;border-radius:6px;cursor:pointer;letter-spacing:0.02em;transition:background 0.2s,color 0.2s;}
.fraik-reviews-btn:hover{background:var(--cyan-deep);color:var(--white);}

/* ---- Lightbox avis ---- */
.review-avatar-photo img{cursor:pointer;}
.fraik-lb{display:none;position:fixed;inset:0;background:rgba(10,22,40,0.88);z-index:9000;align-items:center;justify-content:center;cursor:pointer;}
.fraik-lb.open{display:flex;}
.fraik-lb-img{max-width:88vw;max-height:84vh;border-radius:12px;object-fit:contain;box-shadow:0 8px 40px rgba(0,0,0,0.45);cursor:default;}
.fraik-lb-close{position:absolute;top:18px;right:22px;background:none;border:none;color:#fff;font-size:36px;line-height:1;cursor:pointer;opacity:0.82;padding:4px 8px;}
.fraik-lb-close:hover{opacity:1;}

/* ---- Comment l'utiliser ---- */
.fraik-howto{padding:56px 0;}
.howto-steps{display:flex;align-items:stretch;gap:12px;}
.howto-step{flex:1;display:flex;flex-direction:column;align-items:center;text-align:center;padding:32px 20px 24px;background:var(--ice);border:1px solid var(--line);border-radius:12px;position:relative;}
.howto-num{position:absolute;top:-14px;left:50%;transform:translateX(-50%);width:28px;height:28px;background:var(--cyan-deep);color:var(--white);border-radius:50%;font-family:var(--font-mono);font-size:13px;font-weight:700;display:flex;align-items:center;justify-content:center;}
.howto-icon{margin-bottom:12px;margin-top:4px;}
.howto-text h4{font-size:14px;font-weight:700;color:var(--navy);margin-bottom:5px;line-height:1.3;}
.howto-text p{font-size:12.5px;color:var(--steel);line-height:1.5;margin:0;}
.howto-sep{flex-shrink:0;color:var(--cyan-deep);font-size:22px;font-weight:300;align-self:center;padding:0 4px;line-height:1;}
@media(max-width:820px){.howto-steps{flex-direction:column;}.howto-sep{align-self:center;transform:rotate(90deg);padding:4px 0;}}

/* ---- Comparatif ---- */
.fraik-compare{padding:56px 0 0;}
.compare-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;}
.compare-tbl{width:100%;border-collapse:collapse;min-width:480px;font-size:13px;}
.compare-tbl th,.compare-tbl td{padding:13px 14px;text-align:center;border-bottom:1px solid var(--line);vertical-align:middle;}
.compare-tbl th{font-family:var(--font-mono);font-size:10.5px;font-weight:700;letter-spacing:0.04em;background:var(--ice);color:var(--navy);}
.compare-tbl td:first-child,.compare-tbl th:first-child{text-align:left;font-weight:600;}
.fraik-col{background:rgba(0,146,168,0.05);border-left:2px solid var(--cyan-deep);border-right:2px solid var(--cyan-deep);}
.fraik-col-head{background:var(--ice)!important;color:var(--navy)!important;border-top:2px solid var(--cyan-deep)!important;}
.compare-tbl tbody tr:last-child .fraik-col{border-bottom:2px solid var(--cyan-deep);}
.c-yes{color:var(--cyan-deep);font-weight:700;}
.c-no{color:#B0C4CC;}
.c-mid{color:var(--steel);}
.compare-cards{display:none;}

/* ---- FAQ ---- */
.fraik-faq{padding:56px 0 0;}
.faq-list{max-width:720px;margin:0 auto;}
details.faq-item{border-bottom:1px solid var(--line);}
details.faq-item summary{padding:18px 0;font-size:14px;font-weight:700;color:var(--navy);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;}
details.faq-item summary::-webkit-details-marker{display:none;}
details.faq-item summary::after{content:'+';font-size:20px;color:var(--cyan-deep);font-weight:300;flex-shrink:0;}
details.faq-item[open] summary::after{content:'−';}
.faq-answer{padding:0 0 18px;font-size:13.5px;color:var(--steel);line-height:1.65;}

/* ---- Pourquoi ça marche ---- */
.fraik-pourquoi{padding:56px 0;}
.pourquoi-content{max-width:720px;}
.pourquoi-content h2{font-family:var(--font-display);font-size:24px;font-weight:800;color:var(--navy);line-height:1.25;margin-bottom:14px;}
.pourquoi-content p{font-size:14px;line-height:1.65;color:var(--steel);}
.pourquoi-disclaimer{font-size:12.5px;color:var(--steel);font-style:italic;margin-top:10px;opacity:0.85;}
.pourquoi-steps{display:flex;gap:0;margin-top:44px;align-items:flex-start;}
.pourquoi-step{flex:1;display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 20px;position:relative;}
.pourquoi-step:not(:last-child)::after{content:'→';position:absolute;right:-10px;top:16px;color:var(--cyan-deep);font-size:22px;font-weight:300;line-height:1;}
.pourquoi-step-icon{width:44px;height:44px;margin-bottom:12px;}
.pourquoi-step h4{font-size:13.5px;font-weight:700;color:var(--navy);margin-bottom:0;line-height:1.3;}

/* ---- Sticky ATC mobile ---- */
.sticky-atc{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--white);border-top:1px solid var(--line);padding:12px 16px 16px;z-index:999;box-shadow:0 -4px 20px rgba(10,22,40,0.1);}
.sticky-atc-inner{display:flex;align-items:center;gap:12px;max-width:600px;margin:0 auto;}
.sticky-atc-info{flex:1;min-width:0;}
.sticky-atc-name{display:block;font-family:var(--font-display);font-size:14px;font-weight:700;color:var(--navy);}
.sticky-atc-price{display:block;font-size:13px;font-weight:700;color:var(--cyan-deep);}
.sticky-atc-btn{background:var(--cyan-deep);color:var(--white);border:none;padding:13px 20px;font-size:13.5px;font-weight:800;border-radius:6px;cursor:pointer;white-space:nowrap;flex-shrink:0;}
.sticky-atc-btn:disabled{opacity:0.55;cursor:not-allowed;}

/* ---- Variant picker ---- */
.fraik-variant-picker{margin:16px 0;}
.fraik-option-label{font-family:var(--font-mono);font-size:11px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:8px;}
.fraik-option-selected{color:var(--cyan-deep);text-transform:none;}
.fraik-option-values{display:flex;gap:8px;flex-wrap:wrap;}
.fraik-opt-btn{font-family:var(--font-mono);font-size:12px;font-weight:700;border:2px solid var(--line);background:var(--white);color:var(--navy);padding:7px 18px;border-radius:6px;cursor:pointer;transition:border-color 0.15s,background 0.15s,color 0.15s;letter-spacing:0.04em;}
.fraik-opt-btn:hover{border-color:var(--cyan-deep);color:var(--cyan-deep);}
.fraik-opt-btn.active{border-color:var(--cyan-deep);background:var(--cyan-deep);color:var(--white);}
.fraik-opt-btn[aria-disabled="true"]{opacity:0.4;cursor:not-allowed;pointer-events:none;}

/* ---- Ordre des sections (page flow) ---- */
.fraik-page-flow{display:flex;flex-direction:column;width:100%;}

/* ---- Badge stock urgence ---- */
@keyframes fraik-pulse{0%,100%{opacity:1;}50%{opacity:0.4;}}
.fraik-stock-badge{font-family:var(--font-mono);font-size:11.5px;font-weight:700;color:#D93025;letter-spacing:0.05em;text-align:center;margin-top:10px;animation:fraik-pulse 1.5s ease-in-out infinite;}

@media(max-width:820px){
  .fraik-hero{grid-template-columns:1fr;}
  .fraik-hero h1{font-size:22px;}
  .hero-sub-args{font-size:13.5px;}
  .reassure-grid{grid-template-columns:repeat(2,1fr);}
  .benefits-grid{grid-template-columns:1fr;}
  .avap-grid{grid-template-columns:1fr;}
  .bundle-grid{grid-template-columns:1fr;}

  .clean-grid{grid-template-columns:1fr;}
  .compare-scroll{display:none;}
  .compare-cards{display:flex;flex-direction:column;gap:14px;}
  .ccard{background:var(--white);border:1px solid var(--line);border-radius:10px;overflow:hidden;}
  .ccard-fraik{border:2px solid var(--cyan-deep);}
  .ccard-head{padding:13px 16px;font-family:var(--font-mono);font-size:11px;font-weight:700;letter-spacing:0.05em;color:var(--navy);background:var(--ice);border-bottom:1px solid var(--line);}
  .ccard-fraik .ccard-head{border-bottom:2px solid var(--cyan-deep);}
  .ccard-row{display:flex;justify-content:space-between;align-items:flex-start;padding:11px 16px;border-bottom:1px solid var(--line);gap:10px;font-size:13px;}
  .ccard-row:last-child{border-bottom:none;}
  .ccard-label{color:var(--steel);font-size:11.5px;flex:1;line-height:1.4;}
  .ccard-val{text-align:right;flex-shrink:0;max-width:54%;line-height:1.4;}
  .pourquoi-steps{flex-direction:column;gap:28px;align-items:stretch;}
  .pourquoi-step:not(:last-child)::after{content:'↓';right:auto;top:auto;bottom:-22px;left:50%;transform:translateX(-50%);font-size:18px;}
  .reviews-grid{grid-template-columns:1fr;}
  .sticky-atc.visible{display:block;}
  .fraik-page-flow > *{order:10;min-width:0;}
  .fraik-hero-wrap{order:1;}
  .fraik-bundle-wrap{order:2;}
}
</style>

<div class="marquee-bar">
  <div class="marquee-track">
    <span>&#10052;</span> LIVRAISON OFFERTE &nbsp;&nbsp;·&nbsp;&nbsp; BOUTIQUE FRANÇAISE &nbsp;&nbsp;·&nbsp;&nbsp; PAIEMENT SÉCURISÉ &nbsp;&nbsp;·&nbsp;&nbsp; <span class="mq-urgent">🔴 STOCK LIMITÉ</span> &nbsp;&nbsp;·&nbsp;&nbsp;
    <span>&#10052;</span> LIVRAISON OFFERTE &nbsp;&nbsp;·&nbsp;&nbsp; BOUTIQUE FRANÇAISE &nbsp;&nbsp;·&nbsp;&nbsp; PAIEMENT SÉCURISÉ &nbsp;&nbsp;·&nbsp;&nbsp; <span class="mq-urgent">🔴 STOCK LIMITÉ</span> &nbsp;&nbsp;·&nbsp;&nbsp;
  </div>
</div>

<div class="fraik-page-flow">

<div class="fraik-wrap fraik-hero-wrap">
  <section class="fraik-hero">

    <div class="gallery">
