<script>
(function(){
  var heroBtn = document.querySelector('#fraik-product-form [name="add"]');
  var sticky  = document.getElementById('fraik-sticky-atc');
  if (!heroBtn || !sticky) return;
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { sticky.classList.remove('visible'); sticky.setAttribute('aria-hidden','true'); }
      else { sticky.classList.add('visible'); sticky.setAttribute('aria-hidden','false'); }
    });
  }, { threshold: 0 });
  obs.observe(heroBtn);
})();

function fraikToggleReviews(){
  var el  = document.getElementById('fraik-reviews-more');
  var btn = document.getElementById('fraik-reviews-btn');
  if (!el || !btn) return;
  if (el.style.maxHeight && el.style.maxHeight !== '0px') {
    el.style.maxHeight = '0px';
    btn.textContent = 'Voir plus d\'avis (52) ↓';
  } else {
    el.style.maxHeight = el.scrollHeight + 'px';
    btn.textContent = 'Voir moins d\'avis ↑';
  }
}

function fraikLbOpen(src,alt){
  var lb=document.getElementById('fraik-lb');
  var img=document.getElementById('fraik-lb-img');
  if(!lb||!img)return;
  img.src=src;img.alt=alt||'';
  lb.classList.add('open');
  document.body.style.overflow='hidden';
}
function fraikLbClose(){
  var lb=document.getElementById('fraik-lb');
  if(!lb)return;
  lb.classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown',function(e){if(e.key==='Escape')fraikLbClose();});
document.querySelectorAll('.review-avatar-photo img').forEach(function(img){
  img.addEventListener('click',function(e){e.stopPropagation();fraikLbOpen(this.src,this.alt);});
});
// ---- Bascule galerie image / vidéo ----
function fraikSetActiveThumb(el){
  var wrap=el.closest('.gallery-thumbs');
  if(wrap)wrap.querySelectorAll('.thumb').forEach(function(t){t.classList.remove('active');});
  el.classList.add('active');
}
function fraikShowImage(el){
  var img=document.getElementById('fraik-main-img');
  var vid=document.getElementById('fraik-main-video');
  if(vid){vid.pause();vid.style.display='none';}
  if(img){img.src=el.getAttribute('data-full');img.alt=el.getAttribute('data-alt')||'';img.style.display='';}
  fraikSetActiveThumb(el);
}
function fraikShowVideo(el){
  var img=document.getElementById('fraik-main-img');
  var vid=document.getElementById('fraik-main-video');
  if(img)img.style.display='none';
  if(vid){vid.style.display='';vid.muted=true;try{vid.currentTime=0;}catch(e){}var p=vid.play();if(p&&p.catch)p.catch(function(){});}
  fraikSetActiveThumb(el);
}

var fraikMainImg=document.getElementById('fraik-main-img');
if(fraikMainImg)fraikMainImg.addEventListener('click',function(e){e.stopPropagation();fraikLbOpen(this.src,this.alt);});

// ---- Variant picker ----
(function(){
  if (!document.getElementById('fraik-variant-picker')) return;
  var variants = {{ product.variants | json }};
  var currentVar = variants.find(function(v){ return v.id === {{ current_variant.id }}; }) || variants[0];
  var selOpts = currentVar.options.slice();

  function findVariant(opts) {
    return variants.find(function(v) {
      return v.options.every(function(o, i){ return o === opts[i]; });
    });
  }

  function fmt(cents) {
    return (cents / 100).toFixed(2).replace('.',',') + ' €';
  }

  function applyVariant(v) {
    if (!v) return;
    document.querySelectorAll('input[name="id"]').forEach(function(inp){ inp.value = v.id; });
    var pn = document.querySelector('.price-now');
    var pt = document.querySelector('.price-then');
    var ps = document.querySelector('.price-save');
    var sp = document.querySelector('.sticky-atc-price');
    if (pn) pn.textContent = fmt(v.price);
    if (sp) sp.textContent = fmt(v.price);
    if (v.compare_at_price && v.compare_at_price > v.price) {
      var pct = Math.round((v.compare_at_price - v.price) * 100 / v.compare_at_price);
      if (pt) { pt.textContent = fmt(v.compare_at_price); pt.hidden = false; }
      if (ps) { ps.textContent = '−' + pct + '%'; ps.hidden = false; }
    } else {
      if (pt) pt.hidden = true;
      if (ps) ps.hidden = true;
    }
    var hb = document.querySelector('#fraik-product-form [name="add"]');
    if (hb) {
      if (v.available) { hb.textContent = 'Je veux sentir la fraîcheur → ' + fmt(v.price); hb.disabled = false; hb.removeAttribute('aria-disabled'); }
      else { hb.textContent = 'Rupture de stock'; hb.disabled = true; hb.setAttribute('aria-disabled','true'); }
    }
    ['fraik-bundle-solo','fraik-bundle-duo','fraik-bundle-trio','fraik-product-form-bottom','fraik-sticky-form'].forEach(function(id){
      var btn = document.querySelector('#' + id + ' [name="add"]');
      if (btn) { btn.disabled = !v.available; }
    });
  }

  document.querySelectorAll('.fraik-opt-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var pos = parseInt(this.dataset.optionPos, 10) - 1;
      selOpts[pos] = this.dataset.optionVal;
      this.closest('.fraik-option-values').querySelectorAll('.fraik-opt-btn').forEach(function(b){ b.classList.remove('active'); });
      this.classList.add('active');
      var lbl = document.getElementById('fraik-opt-val-' + this.dataset.optionPos);
      if (lbl) lbl.textContent = this.dataset.optionVal;
      applyVariant(findVariant(selOpts));
    });
  });
})();
</script>

<div class="fraik-lb" id="fraik-lb" role="dialog" aria-modal="true" aria-label="Photo en grand" onclick="if(event.target===this)fraikLbClose()">
  <button class="fraik-lb-close" onclick="fraikLbClose()" aria-label="Fermer">&#215;</button>
  <img class="fraik-lb-img" id="fraik-lb-img" src="" alt="">
</div>

