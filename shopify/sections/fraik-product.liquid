<script>
(function(){
  var counter = document.getElementById('fraik-interest-counter-{{ section.id }}');
  if (!counter) return;
  var number = counter.querySelector('.fraik-interest-number');
  var min = parseInt(counter.dataset.interestMin, 10);
  var max = parseInt(counter.dataset.interestMax, 10);
  var intervalMin = parseInt(counter.dataset.interestIntervalMin, 10) * 1000;
  var intervalMax = parseInt(counter.dataset.interestIntervalMax, 10) * 1000;
  if (!number || !Number.isFinite(min) || !Number.isFinite(max)) return;
  if (max < min) { var swap = min; min = max; max = swap; }
  if (!Number.isFinite(intervalMin) || intervalMin < 1000) intervalMin = 30000;
  if (!Number.isFinite(intervalMax) || intervalMax < intervalMin) intervalMax = 60000;
  function randomInt(low, high){ return Math.floor(Math.random() * (high - low + 1)) + low; }
  function schedule(){
    window.setTimeout(function(){
      number.textContent = randomInt(min, max);
      schedule();
    }, randomInt(intervalMin, intervalMax));
  }
  number.textContent = randomInt(min, max);
  schedule();
})();

(function(){
  var heroBtn = document.querySelector('#fraik-product-form [name="add"]');
  var sticky  = document.getElementById('fraik-sticky-atc');
  if (!heroBtn || !sticky) return;
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.intersectionRatio >= 0.5) { sticky.classList.remove('visible'); sticky.setAttribute('aria-hidden','true'); }
      else { sticky.classList.add('visible'); sticky.setAttribute('aria-hidden','false'); }
    });
  }, { threshold: [0, 0.5] });
  obs.observe(heroBtn);
})();

(function(){
  var root = document.getElementById('fraik-proof-carousel');
  if (!root) return;
  var track = root.querySelector('.proof-track');
  var slides = Array.prototype.slice.call(root.querySelectorAll('.proof-slide'));
  var dots = Array.prototype.slice.call(root.querySelectorAll('.proof-dot'));
  var prev = root.querySelector('.proof-prev');
  var next = root.querySelector('.proof-next');
  var index = 0;
  var timer = null;
  var reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function show(nextIndex){
    index = (nextIndex + slides.length) % slides.length;
    track.style.transform = 'translateX(-' + (index * 100) + '%)';
    slides.forEach(function(slide, i){ slide.setAttribute('aria-hidden', i === index ? 'false' : 'true'); });
    dots.forEach(function(dot, i){
      dot.classList.toggle('active', i === index);
      if (i === index) dot.setAttribute('aria-current','true');
      else dot.removeAttribute('aria-current');
    });
  }

  function stop(){
    if (timer) window.clearInterval(timer);
    timer = null;
  }

  function start(){
    stop();
    if (reducedMotion || document.hidden) return;
    timer = window.setInterval(function(){ show(index + 1); }, 4800);
  }

  prev.addEventListener('click', function(){ show(index - 1); start(); });
  next.addEventListener('click', function(){ show(index + 1); start(); });
  dots.forEach(function(dot, i){ dot.addEventListener('click', function(){ show(i); start(); }); });
  root.addEventListener('mouseenter', stop);
  root.addEventListener('mouseleave', start);
  root.addEventListener('focusin', stop);
  root.addEventListener('focusout', start);
  document.addEventListener('visibilitychange', function(){ if (document.hidden) stop(); else start(); });
  show(0);
  start();
})();

function fraikToggleReviews(){
  var el  = document.getElementById('fraik-reviews-more');
  var btn = document.getElementById('fraik-reviews-btn');
  if (!el || !btn) return;
