<div class="fraik-wrap fraik-howto-wrap">
  <section class="fraik-howto">
    <div class="fraik-section-head">
      <div class="fraik-eyebrow">Utilisation</div>
      <h2>Comment l'utiliser</h2>
    </div>
    <div class="howto-steps">
      <div class="howto-step">
